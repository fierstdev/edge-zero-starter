/// <reference path="./ez-globals.d.ts" />

const meta = {
  name: "Testimonials",
  slug: "testimonials",
  group: "Foundation",
  description: "One Testimonials block with grid, featured, and stacked variants.",
};

const schema: EzField[] = [
  anchorIdField,
  {
    name: 'variant',
    type: 'select',
    defaultValue: 'grid',
    required: true,
    options: [
      { label: 'Grid', value: 'grid' },
      { label: 'Featured', value: 'featured' },
      { label: 'Stacked', value: 'stacked' },
    ],
    admin: {
      description: 'Choose how testimonials are presented.',
    },
  },
  badgeField,
  {
    name: 'heading',
    type: 'text',
    required: true,
  },
  {
    name: 'subheading',
    type: 'textarea',
  },
  {
    name: 'featuredEyebrow',
    type: 'text',
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        siblingData?.variant === 'featured',
    },
  },
  {
    name: 'testimonials',
    type: 'array',
    required: true,
    labels: {
      singular: 'Testimonial',
      plural: 'Testimonials',
    },
    validate: (value: any) => {
      if (!Array.isArray(value) || value.length === 0) {
        return 'Add at least one testimonial.';
      }
      return true;
    },
    fields: [
      {
        name: 'quote',
        type: 'textarea',
        required: true,
      },
      {
        name: 'authorName',
        type: 'text',
        required: true,
      },
      {
        name: 'authorRole',
        type: 'text',
      },
      {
        name: 'authorCompany',
        type: 'text',
      },
      {
        name: 'authorImage',
        type: 'upload',
        relationTo: 'media',
      },
      {
        name: 'rating',
        type: 'number',
        defaultValue: 5,
        min: 1,
        max: 5,
      },
    ],
  },
];

const ez = defineEzBlock({ meta, schema });
const block = (Astro.props.block ?? Astro.props) as typeof ez.block;

const anchorId = block.anchorId;
const variant = block.variant || 'grid';
const badge = block.badge;
const heading = block.heading;
const subheading = block.subheading;
const featuredEyebrow = block.featuredEyebrow;
const testimonials = block.testimonials;

const badgeClass = badge?.color ? `badge-${badge.color}` : 'badge-primary';
const sectionId = anchorId || `${block?.id || 'testimonials'}-section`;
const headingId = `${sectionId}-heading`;
const testimonialItems = Array.isArray(testimonials) ? testimonials : [];
const [featuredTestimonial, ...remainingTestimonials] = testimonialItems;

const getRatingValue = (rating: any) => Math.max(1, Math.min(5, Number(rating || 5)));
const getImageUrl = (item: any) => resolveMediaUrl(item?.authorImage, ['avatar', 'thumbnail', 'card']);
const getImageSrcSet = (item: any) => resolveMediaSrcSet(item?.authorImage, ['thumbnail', 'avatar', 'card']);
const getImageDimensions = (item: any) => resolveMediaDimensions(item?.authorImage, ['avatar', 'thumbnail', 'card']);
const featuredImageUrl = getImageUrl(featuredTestimonial);
const featuredImageSrcSet = getImageSrcSet(featuredTestimonial);
const featuredImageDimensions = getImageDimensions(featuredTestimonial);

---

<section id={anchorId || undefined} aria-labelledby={headingId} class="px-4 py-14 sm:py-18">
  <div class="mx-auto max-w-6xl space-y-8">
    <header class="max-w-3xl space-y-4">
      {badge?.label && (
        <span class={`badge ${badgeClass} ${badge?.size ? `badge-${badge.size}` : ''}`}>
          {badge.label}
        </span>
      )}
      <h2 id={headingId} class="text-3xl font-bold tracking-tight sm:text-4xl">{heading}</h2>
      {subheading && <p class="text-base text-base-content/80 sm:text-lg">{subheading}</p>}
    </header>

    {variant === 'grid' && (
      <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
        {testimonialItems.map((item: any) => {
          const imageUrl = getImageUrl(item);
          const imageSrcSet = getImageSrcSet(item);
          const imageDimensions = getImageDimensions(item);
          const ratingValue = getRatingValue(item.rating);
          return (
            <article class="card card-border bg-base-100 h-full shadow-sm">
              <div class="card-body gap-5">
                <p class="sr-only">Rating: {ratingValue} out of 5</p>
                <div class="rating rating-sm" aria-hidden="true">
                  {Array.from({ length: 5 }).map((_, index) => (
                    <div
                      class:list={[
                        'mask mask-star-2',
                        index < ratingValue ? 'bg-warning' : 'bg-base-300',
                      ]}
                      aria-hidden="true"
                    />
                  ))}
                </div>

                <p class="text-base leading-relaxed text-base-content/80">{item.quote}</p>

                <div class="mt-auto flex items-center gap-3 pt-2">
                  <div class="avatar">
                    <div class="size-12 rounded-full border border-base-300 bg-base-200">
                      {imageUrl ? (
                        <img
                          src={imageUrl}
                          srcset={imageSrcSet}
                          alt={item.authorImage?.altText || ''}
                          loading="lazy"
                          decoding="async"
                          width={imageDimensions.width || 96}
                          height={imageDimensions.height || 96}
                          sizes="48px"
                        />
                      ) : (
                        <div class="grid h-full w-full place-items-center text-sm font-semibold">
                          {item.authorName?.charAt(0)}
                        </div>
                      )}
                    </div>
                  </div>
                  <div>
                    <p class="font-semibold leading-tight">{item.authorName}</p>
                    {(item.authorRole || item.authorCompany) && (
                      <p class="text-sm text-base-content/80">
                        {[item.authorRole, item.authorCompany].filter(Boolean).join(' · ')}
                      </p>
                    )}
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}

    {variant === 'featured' && featuredTestimonial && (
      <div class="grid gap-5 lg:grid-cols-12">
        <article class="card card-border bg-base-100 shadow-sm lg:col-span-7">
          <div class="card-body gap-5 sm:p-8">
            {featuredEyebrow && <p class="text-xs font-semibold uppercase tracking-wider text-base-content/75">{featuredEyebrow}</p>}

            <p class="sr-only">Rating: {getRatingValue(featuredTestimonial.rating)} out of 5</p>
            <div class="rating rating-sm" aria-hidden="true">
              {Array.from({ length: 5 }).map((_, index) => (
                <div
                  class:list={[
                    'mask mask-star-2',
                    index < getRatingValue(featuredTestimonial.rating) ? 'bg-warning' : 'bg-base-300',
                  ]}
                  aria-hidden="true"
                />
              ))}
            </div>

            <blockquote class="text-2xl font-medium leading-snug text-base-content/90">
              “{featuredTestimonial.quote}”
            </blockquote>

            <div class="flex items-center gap-3 pt-2">
              <div class="avatar">
                <div class="size-14 rounded-full border border-base-300 bg-base-200">
                  {featuredImageUrl ? (
                    <img
                      src={featuredImageUrl}
                      srcset={featuredImageSrcSet}
                      alt={featuredTestimonial.authorImage?.altText || ''}
                      loading="lazy"
                      decoding="async"
                      width={featuredImageDimensions.width || 112}
                      height={featuredImageDimensions.height || 112}
                      sizes="56px"
                    />
                  ) : (
                    <div class="grid h-full w-full place-items-center text-base font-semibold">
                      {featuredTestimonial.authorName?.charAt(0)}
                    </div>
                  )}
                </div>
              </div>
              <div>
                <p class="font-semibold">{featuredTestimonial.authorName}</p>
                {(featuredTestimonial.authorRole || featuredTestimonial.authorCompany) && (
                  <p class="text-sm text-base-content/80">
                    {[featuredTestimonial.authorRole, featuredTestimonial.authorCompany].filter(Boolean).join(' · ')}
                  </p>
                )}
              </div>
            </div>
          </div>
        </article>

        <div class="space-y-4 lg:col-span-5">
          {remainingTestimonials.slice(0, 3).map((item: any) => (
            <article class="card card-border bg-base-100 shadow-sm">
              <div class="card-body gap-3">
                <p class="text-sm leading-relaxed text-base-content/80">“{item.quote}”</p>
                <p class="text-sm font-semibold">{item.authorName}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    )}

    {variant === 'stacked' && (
      <div class="space-y-4">
        {testimonialItems.map((item: any) => (
          <article class="card card-border bg-base-100 shadow-sm">
            <div class="card-body gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div class="space-y-3 sm:max-w-4/5">
                <p class="text-base leading-relaxed text-base-content/80">“{item.quote}”</p>
                <p class="text-sm font-semibold">{item.authorName}</p>
              </div>
              <p class="sr-only">Rating: {getRatingValue(item.rating)} out of 5</p>
              <div class="rating rating-sm shrink-0" aria-hidden="true">
                {Array.from({ length: 5 }).map((_, index) => (
                  <div
                    class:list={[
                      'mask mask-star-2',
                      index < getRatingValue(item.rating) ? 'bg-warning' : 'bg-base-300',
                    ]}
                    aria-hidden="true"
                  />
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
