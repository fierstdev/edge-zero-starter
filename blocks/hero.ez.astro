/// <reference path="./ez-globals.d.ts" />

const meta = {
  name: "Hero",
  slug: "hero",
  group: "Foundation",
  description: "One Hero block with multiple visual variants and CMS-smart conditional fields.",
};

const schema: EzField[] = [
  anchorIdField,
  {
    name: 'variant',
    type: 'select',
    defaultValue: 'split',
    required: true,
    options: [
      { label: 'Split', value: 'split' },
      { label: 'Centered', value: 'centered' },
      { label: 'Cinematic', value: 'cinematic' },
      { label: 'Diagonal Split', value: 'diagonal-split' },
    ],
    admin: {
      description: 'Choose a hero layout. Field visibility below adapts to the selected variant.',
    },
  },
  badgeField,
  {
    name: 'headline',
    type: 'text',
    required: true,
  },
  {
    name: 'subheading',
    type: 'textarea',
    required: true,
  },
  {
    type: 'row',
    fields: [
      {
        ...linkField,
        name: 'primaryAction',
        label: 'Primary Action',
        required: true,
      },
      {
        ...linkField,
        name: 'secondaryAction',
        label: 'Secondary Action',
      },
    ],
  },
  {
    name: 'highlights',
    type: 'array',
    labels: {
      singular: 'Highlight',
      plural: 'Highlights',
    },
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        ['split', 'diagonal-split', 'cinematic'].includes(String(siblingData?.variant || '')),
    },
    fields: [
      {
        name: 'value',
        type: 'text',
        required: true,
      },
      {
        name: 'label',
        type: 'text',
        required: true,
      },
    ],
  },
  {
    name: 'media',
    type: 'upload',
    relationTo: 'media',
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        ['split', 'diagonal-split'].includes(String(siblingData?.variant || '')),
    },
    validate: (value: any, { siblingData }: { siblingData?: EzSiblingData }) => {
      const activeVariant = String(siblingData?.variant || 'split');
      if (['split', 'diagonal-split'].includes(activeVariant) && !value) {
        return 'Media is required for Split and Diagonal Split variants.';
      }
      return true;
    },
  },
  {
    name: 'mediaPosition',
    type: 'select',
    defaultValue: 'right',
    options: [
      { label: 'Left', value: 'left' },
      { label: 'Right', value: 'right' },
    ],
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        siblingData?.variant === 'split',
    },
  },
  {
    name: 'backgroundImage',
    type: 'upload',
    relationTo: 'media',
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        siblingData?.variant === 'cinematic',
    },
    validate: (value: any, { siblingData }: { siblingData?: EzSiblingData }) => {
      if ((siblingData?.variant || 'split') === 'cinematic' && !value) {
        return 'Background image is required for the Cinematic variant.';
      }
      return true;
    },
  },
  {
    name: 'panelEyebrow',
    type: 'text',
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        siblingData?.variant === 'cinematic',
    },
  },
  {
    name: 'panelStatusText',
    type: 'text',
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        siblingData?.variant === 'cinematic',
    },
  },
  {
    name: 'cinematicToneMode',
    type: 'select',
    defaultValue: 'auto',
    options: [
      { label: 'Auto Detect', value: 'auto' },
      { label: 'Light Text', value: 'light' },
      { label: 'Dark Text', value: 'dark' },
    ],
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        siblingData?.variant === 'cinematic',
      description:
        'Auto detects image brightness behind the content area. Use manual tone when art direction requires it.',
    },
  },
  {
    name: 'diagonalAccentLabel',
    type: 'text',
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        siblingData?.variant === 'diagonal-split',
    },
  },
];

const ez = defineEzBlock({ meta, schema });
const block = (Astro.props.block ?? Astro.props) as typeof ez.block;

const anchorId = block.anchorId;
const variant = block.variant || 'split';
const badge = block.badge;
const headline = block.headline;
const subheading = block.subheading;
const primaryAction = block.primaryAction;
const secondaryAction = block.secondaryAction;
const highlights = Array.isArray(block.highlights) ? block.highlights : [];
const media = block.media;
const mediaPosition = block.mediaPosition;
const backgroundImage = block.backgroundImage;
const panelEyebrow = block.panelEyebrow;
const panelStatusText = block.panelStatusText;
const cinematicToneMode = block.cinematicToneMode || 'auto';
const diagonalAccentLabel = block.diagonalAccentLabel;
const blockIndex = Number(block.blockIndex || 0);

const heroMediaSizeOrder = ['thumbnail', 'card', 'feature', 'hero'];
const splitMediaUrl = resolveMediaUrl(media, ['feature', 'card', 'thumbnail', 'hero']);
const cinematicMediaUrl = resolveMediaUrl(backgroundImage, ['feature', 'card', 'thumbnail', 'hero']);
const splitMediaSrcSet = resolveMediaSrcSet(media, heroMediaSizeOrder);
const cinematicMediaSrcSet = resolveMediaSrcSet(backgroundImage, heroMediaSizeOrder);
const splitMediaDimensions = resolveMediaDimensions(media, ['card', 'feature', 'hero']);
const cinematicMediaDimensions = resolveMediaDimensions(backgroundImage, ['feature', 'hero']);
const badgeClass = badge?.color ? `badge-${badge.color}` : 'badge-primary';
const sectionId = anchorId || `${block?.id || 'hero'}-section`;
const headingId = `${sectionId}-heading`;
const hasHighlights = highlights.length > 0;
const useLeftMedia = mediaPosition === 'left';
const isPriorityMedia = blockIndex === 0;
const isFirstHeroBlock = blockIndex === 0;
const usesFullBleedContainer = variant === 'cinematic' && isFirstHeroBlock;
const sectionClasses = usesFullBleedContainer
  ? 'relative py-0'
  : isFirstHeroBlock
    ? 'px-4 py-0'
    : 'px-4 py-14 sm:py-18 lg:py-24';
const containerClasses = usesFullBleedContainer ? 'w-full' : 'mx-auto max-w-6xl';
const foldMinHeightClass = 'min-h-[calc(100svh-4rem)]';
const cinematicRootId = `${sectionId}-cinematic`;
const resolvedCinematicTone = cinematicToneMode === 'dark' ? 'dark' : 'light';
const cinematicIsDarkTone = resolvedCinematicTone === 'dark';
const shouldAutoDetectCinematicTone = cinematicToneMode === 'auto';
const cinematicSizes = usesFullBleedContainer ? '100vw' : '(min-width: 1200px) 1152px, 100vw';

const toButtonClass = (action?: any) => {
  const styleClass = action?.style ? `btn-${action.style}` : 'btn-primary';
  const sizeClass = action?.size ? `btn-${action.size}` : 'btn-md';
  return `btn ${styleClass} ${sizeClass} w-full sm:w-auto`;
};
const mediaFetchPriorityAttrs = (isPriorityMedia ? { fetchpriority: 'high' } : {}) as any;

---

<section id={anchorId || undefined} aria-labelledby={headingId} class={sectionClasses}>
  <div class={containerClasses}>
    {variant === 'split' && (
      <div class:list={['hero overflow-hidden bg-base-200/35', isFirstHeroBlock ? foldMinHeightClass : '']}>
        <div class:list={[
          'hero-content w-full gap-8 p-6 sm:p-10 lg:p-14',
          useLeftMedia ? 'flex-col lg:flex-row-reverse' : 'flex-col lg:flex-row',
        ]}>
          {splitMediaUrl && (
            <figure class="w-full lg:w-5/12">
              <img
                src={splitMediaUrl}
                srcset={splitMediaSrcSet}
                alt={media?.altText || ''}
                class="w-full rounded-box object-cover aspect-4/3"
                loading={isPriorityMedia ? 'eager' : 'lazy'}
                {...mediaFetchPriorityAttrs}
                decoding="async"
                width={splitMediaDimensions.width || undefined}
                height={splitMediaDimensions.height || undefined}
                sizes="(min-width: 1200px) 460px, (min-width: 1024px) 40vw, 100vw"
              />
            </figure>
          )}

          <div class="w-full lg:w-7/12 space-y-6">
            {badge?.label && (
              <span class={`badge ${badgeClass} ${badge?.size ? `badge-${badge.size}` : ''}`}>
                {badge.label}
              </span>
            )}

            <h2 id={headingId} class="text-4xl font-black leading-tight tracking-tight sm:text-5xl lg:text-6xl">
              {headline}
            </h2>

            <p class="max-w-2xl text-base text-base-content/75 sm:text-lg">
              {subheading}
            </p>

            {hasHighlights && (
              <ul class="grid overflow-hidden rounded-box border border-base-300 bg-base-100 sm:grid-cols-3">
                {highlights.map((item: any, index: number) => (
                  <li
                    class:list={[
                      'p-4 sm:p-5',
                      index < highlights.length - 1 ? 'border-b border-base-300 sm:border-b-0 sm:border-r' : '',
                    ]}
                  >
                    <p class="text-2xl font-bold sm:text-3xl">{item.value}</p>
                    <p class="mt-1 text-sm text-base-content/80">{item.label}</p>
                  </li>
                ))}
              </ul>
            )}

            <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
              {primaryAction?.url && primaryAction?.label && (
                <a
                  href={primaryAction.url}
                  target={primaryAction.target === '_blank' ? '_blank' : undefined}
                  rel={primaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                  class={toButtonClass(primaryAction)}
                >
                  {primaryAction.label}
                </a>
              )}
              {secondaryAction?.url && secondaryAction?.label && (
                <a
                  href={secondaryAction.url}
                  target={secondaryAction.target === '_blank' ? '_blank' : undefined}
                  rel={secondaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                  class={toButtonClass(secondaryAction)}
                >
                  {secondaryAction.label}
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    )}

    {variant === 'centered' && (
      <div class:list={['hero bg-base-200/25', isFirstHeroBlock ? foldMinHeightClass : '']}>
        <div class:list={['hero-content text-center', isFirstHeroBlock ? 'py-10 sm:py-12' : 'py-12 sm:py-16']}>
          <div class="max-w-3xl space-y-5">
            {badge?.label && (
              <span class={`badge ${badgeClass} ${badge?.size ? `badge-${badge.size}` : ''}`}>
                {badge.label}
              </span>
            )}

            <h2 id={headingId} class="text-4xl font-black tracking-tight sm:text-5xl lg:text-6xl">
              {headline}
            </h2>

            <p class="text-base text-base-content/75 sm:text-lg">{subheading}</p>

            <div class="flex flex-col justify-center gap-3 pt-2 sm:flex-row sm:flex-wrap">
              {primaryAction?.url && primaryAction?.label && (
                <a
                  href={primaryAction.url}
                  target={primaryAction.target === '_blank' ? '_blank' : undefined}
                  rel={primaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                  class={toButtonClass(primaryAction)}
                >
                  {primaryAction.label}
                </a>
              )}
              {secondaryAction?.url && secondaryAction?.label && (
                <a
                  href={secondaryAction.url}
                  target={secondaryAction.target === '_blank' ? '_blank' : undefined}
                  rel={secondaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                  class={toButtonClass(secondaryAction)}
                >
                  {secondaryAction.label}
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    )}

    {variant === 'cinematic' && (
      <div
        id={cinematicRootId}
        class:list={[
          'hero relative overflow-hidden bg-base-100',
          usesFullBleedContainer ? foldMinHeightClass : 'min-h-[28rem] rounded-box border border-base-300 shadow-sm',
        ]}
        data-tone={resolvedCinematicTone}
        data-immersive={usesFullBleedContainer ? 'true' : 'false'}
      >
        {cinematicMediaUrl && (
          <img
            src={cinematicMediaUrl}
            srcset={cinematicMediaSrcSet}
            alt={backgroundImage?.altText || ''}
            class="absolute inset-0 h-full w-full object-cover"
            loading={isPriorityMedia ? 'eager' : 'lazy'}
            {...mediaFetchPriorityAttrs}
            decoding="async"
            width={cinematicMediaDimensions.width || undefined}
            height={cinematicMediaDimensions.height || undefined}
            sizes={cinematicSizes}
          />
        )}
        <div
          data-tone-target="overlay"
          class:list={[
            'hero-overlay',
            usesFullBleedContainer
              ? cinematicIsDarkTone
                ? 'bg-gradient-to-b from-white/22 via-white/46 to-white/72'
                : 'bg-gradient-to-b from-base-100/35 via-base-100/56 to-base-100/82'
              : cinematicIsDarkTone
                ? 'bg-white/58'
                : 'bg-base-100/62',
          ]}
        ></div>

        <div
          class:list={[
            'hero-content relative w-full',
            usesFullBleedContainer ? `${foldMinHeightClass} p-4 sm:p-8 lg:p-12` : 'p-6 sm:p-10 lg:p-14',
          ]}
        >
          <div class:list={['grid w-full gap-8', usesFullBleedContainer ? 'mx-auto max-w-6xl lg:grid-cols-5' : 'lg:grid-cols-5']}>
            <div class="space-y-6 lg:col-span-3">
              {badge?.label && (
                <span class={`badge ${badgeClass} ${badge?.size ? `badge-${badge.size}` : ''}`}>
                  {badge.label}
                </span>
              )}

              <h2
                id={headingId}
                data-tone-target="headline"
                class:list={[
                  'font-black leading-tight tracking-tight',
                  cinematicIsDarkTone ? 'text-slate-950' : 'text-white',
                  usesFullBleedContainer ? 'text-4xl sm:text-6xl lg:text-7xl' : 'text-4xl sm:text-5xl lg:text-6xl',
                ]}
              >
                {headline}
              </h2>
              <p data-tone-target="body" class:list={['max-w-2xl text-base sm:text-lg', cinematicIsDarkTone ? 'text-slate-700' : 'text-slate-100']}>
                {subheading}
              </p>

              <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                {primaryAction?.url && primaryAction?.label && (
                  <a
                    href={primaryAction.url}
                    target={primaryAction.target === '_blank' ? '_blank' : undefined}
                    rel={primaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                    class={toButtonClass(primaryAction)}
                  >
                    {primaryAction.label}
                  </a>
                )}
                {secondaryAction?.url && secondaryAction?.label && (
                  <a
                    href={secondaryAction.url}
                    target={secondaryAction.target === '_blank' ? '_blank' : undefined}
                    rel={secondaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                    class={toButtonClass(secondaryAction)}
                  >
                    {secondaryAction.label}
                  </a>
                )}
              </div>
            </div>

            {(panelEyebrow || panelStatusText || hasHighlights) && (
              <aside
                data-tone-target="panel"
                class:list={[
                  'card card-border backdrop-blur lg:col-span-2',
                  cinematicIsDarkTone
                    ? 'border-slate-900/10 bg-white/80 text-slate-900'
                    : 'border-white/20 bg-slate-950/50 text-slate-100',
                ]}
              >
                <div class="card-body gap-4">
                  {panelEyebrow && (
                    <p
                      data-tone-target="muted"
                      class:list={[
                        'text-sm font-semibold uppercase tracking-wider',
                        cinematicIsDarkTone ? 'text-slate-600' : 'text-slate-200/85',
                      ]}
                    >
                      {panelEyebrow}
                    </p>
                  )}
                  {panelStatusText && <p class="text-xl font-bold">{panelStatusText}</p>}

                  {hasHighlights && (
                    <ul class="space-y-2 text-sm">
                      {highlights.map((item: any) => (
                        <li
                          data-tone-target="divider"
                          class:list={[
                            'flex items-center justify-between gap-3 border-b pb-2 last:border-b-0 last:pb-0',
                            cinematicIsDarkTone ? 'border-slate-900/15' : 'border-white/25',
                          ]}
                        >
                          <span
                            data-tone-target="muted"
                            class:list={[cinematicIsDarkTone ? 'text-slate-600' : 'text-slate-200/85']}
                          >
                            {item.label}
                          </span>
                          <span class="font-semibold">{item.value}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </aside>
            )}
          </div>
        </div>
      </div>
    )}

    {variant === 'diagonal-split' && (
      <div class:list={['grid items-center gap-8 overflow-hidden bg-base-200/30 p-6 sm:p-10 lg:grid-cols-12 lg:p-14', isFirstHeroBlock ? foldMinHeightClass : '']}>
        <div class="order-2 space-y-6 lg:order-1 lg:col-span-6">
          <div class="flex flex-wrap items-center gap-2">
            {badge?.label && (
              <span class={`badge ${badgeClass} ${badge?.size ? `badge-${badge.size}` : ''}`}>
                {badge.label}
              </span>
            )}
            {diagonalAccentLabel && <span class="badge badge-outline">{diagonalAccentLabel}</span>}
          </div>

          <h2 id={headingId} class="text-4xl font-black leading-tight tracking-tight sm:text-5xl">
            {headline}
          </h2>
          <p class="text-base text-base-content/75 sm:text-lg">{subheading}</p>

            {hasHighlights && (
            <ul class="grid overflow-hidden rounded-box border border-base-300 bg-base-100 sm:grid-cols-3">
              {highlights.map((item: any, index: number) => (
                <li
                  class:list={[
                    'p-4 sm:p-5',
                    index < highlights.length - 1 ? 'border-b border-base-300 sm:border-b-0 sm:border-r' : '',
                  ]}
                >
                  <p class="text-2xl font-bold">{item.value}</p>
                  <p class="text-sm text-base-content/80">{item.label}</p>
                </li>
              ))}
            </ul>
          )}

          <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            {primaryAction?.url && primaryAction?.label && (
              <a
                href={primaryAction.url}
                target={primaryAction.target === '_blank' ? '_blank' : undefined}
                rel={primaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                class={toButtonClass(primaryAction)}
              >
                {primaryAction.label}
              </a>
            )}
            {secondaryAction?.url && secondaryAction?.label && (
              <a
                href={secondaryAction.url}
                target={secondaryAction.target === '_blank' ? '_blank' : undefined}
                rel={secondaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                class={toButtonClass(secondaryAction)}
              >
                {secondaryAction.label}
              </a>
            )}
          </div>
        </div>

        {splitMediaUrl && (
          <figure class="order-1 overflow-hidden rounded-box lg:order-2 lg:col-span-6 lg:[clip-path:polygon(9%_0,100%_0,91%_100%,0_100%)]">
            <img
              src={splitMediaUrl}
              srcset={splitMediaSrcSet}
              alt={media?.altText || ''}
              class="h-full w-full object-cover"
              loading={isPriorityMedia ? 'eager' : 'lazy'}
              {...mediaFetchPriorityAttrs}
              decoding="async"
              width={splitMediaDimensions.width || undefined}
              height={splitMediaDimensions.height || undefined}
              sizes="(min-width: 1200px) 576px, (min-width: 1024px) 50vw, 100vw"
            />
          </figure>
        )}
      </div>
    )}
  </div>
</section>

{variant === 'cinematic' && cinematicMediaUrl && shouldAutoDetectCinematicTone && (
  <script is:inline define:vars={{ cinematicRootId }}>
    (() => {
      const root = document.getElementById(cinematicRootId);
      if (!root) return;

      const img = root.querySelector('img');
      if (!(img instanceof HTMLImageElement)) return;

      const applyTone = (tone) => {
        root.setAttribute('data-tone', tone);
        const headlineTargets = root.querySelectorAll('[data-tone-target="headline"]');
        const bodyTargets = root.querySelectorAll('[data-tone-target="body"]');
        const mutedTargets = root.querySelectorAll('[data-tone-target="muted"]');
        const panelTargets = root.querySelectorAll('[data-tone-target="panel"]');
        const overlayTargets = root.querySelectorAll('[data-tone-target="overlay"]');
        const dividerTargets = root.querySelectorAll('[data-tone-target="divider"]');
        const isImmersive = root.dataset.immersive === 'true';

        headlineTargets.forEach((el) => {
          el.classList.remove('text-white', 'text-slate-950');
          el.classList.add(tone === 'dark' ? 'text-slate-950' : 'text-white');
        });

        bodyTargets.forEach((el) => {
          el.classList.remove('text-slate-100', 'text-slate-700');
          el.classList.add(tone === 'dark' ? 'text-slate-700' : 'text-slate-100');
        });

        mutedTargets.forEach((el) => {
          el.classList.remove('text-slate-200/85', 'text-slate-600');
          el.classList.add(tone === 'dark' ? 'text-slate-600' : 'text-slate-200/85');
        });

        panelTargets.forEach((el) => {
          el.classList.remove(
            'bg-slate-950/50',
            'text-slate-100',
            'border-white/20',
            'bg-white/80',
            'text-slate-900',
            'border-slate-900/10',
          );
          if (tone === 'dark') {
            el.classList.add('bg-white/80', 'text-slate-900', 'border-slate-900/10');
          } else {
            el.classList.add('bg-slate-950/50', 'text-slate-100', 'border-white/20');
          }
        });

        overlayTargets.forEach((el) => {
          el.classList.remove(
            'bg-gradient-to-b',
            'from-base-100/35',
            'via-base-100/56',
            'to-base-100/82',
            'bg-base-100/62',
            'from-white/22',
            'via-white/46',
            'to-white/72',
            'bg-white/58',
          );
          if (isImmersive) {
            el.classList.add('bg-gradient-to-b');
            if (tone === 'dark') {
              el.classList.add('from-white/22', 'via-white/46', 'to-white/72');
            } else {
              el.classList.add('from-base-100/35', 'via-base-100/56', 'to-base-100/82');
            }
          } else {
            el.classList.add(tone === 'dark' ? 'bg-white/58' : 'bg-base-100/62');
          }
        });

        dividerTargets.forEach((el) => {
          el.classList.remove('border-white/25', 'border-slate-900/15');
          el.classList.add(tone === 'dark' ? 'border-slate-900/15' : 'border-white/25');
        });
      };

      const detectTone = () => {
        try {
          const canvas = document.createElement('canvas');
          const context = canvas.getContext('2d', { willReadFrequently: true });
          if (!context) return;

          const width = 48;
          const height = 48;
          canvas.width = width;
          canvas.height = height;

          const sourceWidth = Math.max(1, Math.floor(img.naturalWidth * 0.62));
          const sourceHeight = Math.max(1, Math.floor(img.naturalHeight * 0.7));

          context.drawImage(img, 0, 0, sourceWidth, sourceHeight, 0, 0, width, height);

          const { data } = context.getImageData(0, 0, width, height);
          let luminanceTotal = 0;

          for (let index = 0; index < data.length; index += 4) {
            const red = data[index];
            const green = data[index + 1];
            const blue = data[index + 2];
            luminanceTotal += 0.2126 * red + 0.7152 * green + 0.0722 * blue;
          }

          const pixelCount = data.length / 4;
          const averageLuminance = pixelCount > 0 ? luminanceTotal / pixelCount : 0;
          applyTone(averageLuminance > 156 ? 'dark' : 'light');
        } catch {
          applyTone('light');
        }
      };

      if (img.complete) {
        detectTone();
      } else {
        img.addEventListener('load', detectTone, { once: true });
        img.addEventListener('error', () => applyTone('light'), { once: true });
      }
    })();
  </script>
)}
