/// <reference path="./ez-globals.d.ts" />

const meta = {
  name: "Logos",
  slug: "logos",
  group: "Foundation",
  description: "One Logos block with grid, strip, and monochrome variants.",
};

const schema: EzField[] = [
  anchorIdField,
  {
    name: 'variant',
    type: 'select',
    defaultValue: 'grid',
    required: true,
    options: [
      { label: 'Grid', value: 'grid' },
      { label: 'Strip', value: 'strip' },
      { label: 'Monochrome', value: 'monochrome' },
    ],
    admin: {
      description: 'Choose logo layout. Available options adapt to the selected variant.',
    },
  },
  {
    name: 'heading',
    type: 'text',
    required: true,
  },
  {
    name: 'subheading',
    type: 'textarea',
  },
  {
    name: 'columns',
    type: 'select',
    defaultValue: '6',
    options: [
      { label: '3 Columns', value: '3' },
      { label: '4 Columns', value: '4' },
      { label: '5 Columns', value: '5' },
      { label: '6 Columns', value: '6' },
    ],
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        ['grid', 'monochrome'].includes(String(siblingData?.variant || '')),
    },
  },
  {
    name: 'stripItemWidth',
    type: 'select',
    defaultValue: 'md',
    options: [
      { label: 'Small', value: 'sm' },
      { label: 'Medium', value: 'md' },
      { label: 'Large', value: 'lg' },
    ],
    admin: {
      condition: (_data: Record<string, any> | undefined, siblingData: EzSiblingData) =>
        siblingData?.variant === 'strip',
    },
  },
  {
    name: 'logos',
    type: 'array',
    required: true,
    labels: {
      singular: 'Logo',
      plural: 'Logos',
    },
    validate: (value: any) => {
      if (!Array.isArray(value) || value.length === 0) {
        return 'Add at least one logo.';
      }
      return true;
    },
    fields: [
      {
        name: 'media',
        type: 'upload',
        relationTo: 'media',
        required: true,
      },
      {
        name: 'url',
        type: 'text',
      },
    ],
  },
];

const ez = defineEzBlock({ meta, schema });
const block = (Astro.props.block ?? Astro.props) as typeof ez.block;

const anchorId = block.anchorId;
const variant = block.variant || 'grid';
const heading = block.heading;
const subheading = block.subheading;
const columns = block.columns;
const stripItemWidth = block.stripItemWidth;
const logos = block.logos;

const sectionId = anchorId || `${block?.id || 'logos'}-section`;
const headingId = `${sectionId}-heading`;
const logoItems = Array.isArray(logos) ? logos : [];

const gridClass =
  columns === '3'
    ? 'grid-cols-2 sm:grid-cols-3'
    : columns === '4'
      ? 'grid-cols-2 sm:grid-cols-4'
      : columns === '5'
        ? 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-5'
        : 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-6';

const stripWidthClass =
  stripItemWidth === 'sm'
    ? 'w-28 sm:w-32'
    : stripItemWidth === 'lg'
      ? 'w-44 sm:w-52'
      : 'w-36 sm:w-44';

const imageClass =
  variant === 'monochrome'
    ? 'max-h-9 w-auto object-contain grayscale opacity-70 transition hover:grayscale-0 hover:opacity-100'
    : 'max-h-9 w-auto object-contain opacity-85';
const logoSizeOrder = ['thumbnail', 'logo', 'card'];
const getLogoUrl = (item: any) => resolveMediaUrl(item?.media, ['logo', 'thumbnail', 'card']);
const getLogoSrcSet = (item: any) => resolveMediaSrcSet(item?.media, logoSizeOrder);
const getLogoDimensions = (item: any) => resolveMediaDimensions(item?.media, ['logo', 'thumbnail', 'card']);
const getLogoLabel = (item: any, index: number) => {
  const explicitAlt = String(item?.media?.altText || '').trim();
  if (explicitAlt) return explicitAlt;
  return `Partner logo ${index + 1}`;
};

---

<section id={anchorId || undefined} aria-labelledby={headingId} class="px-4 py-14 sm:py-18">
  <div class="mx-auto max-w-6xl space-y-8">
    <header class="max-w-3xl space-y-3">
      <h2 id={headingId} class="text-3xl font-bold tracking-tight sm:text-4xl">{heading}</h2>
      {subheading && <p class="text-base text-base-content/80 sm:text-lg">{subheading}</p>}
    </header>

    {variant === 'strip' ? (
      <div class="carousel carousel-center w-full gap-3 bg-base-200/25 p-3">
        {logoItems.map((item: any, index: number) => {
          const logoUrl = getLogoUrl(item);
          const logoSrcSet = getLogoSrcSet(item);
          const logoDimensions = getLogoDimensions(item);
          const logoLabel = getLogoLabel(item, index);
          return (
            <div class:list={['carousel-item', stripWidthClass]}>
              {item.url ? (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={logoLabel}
                  class="card bg-base-100/80 h-full w-full transition hover:bg-base-100"
                >
                  <div class="card-body flex h-20 items-center justify-center p-4">
                    {logoUrl && (
                      <img
                        src={logoUrl}
                        srcset={logoSrcSet}
                        alt={logoLabel}
                        class={imageClass}
                        loading="lazy"
                        decoding="async"
                        width={logoDimensions.width || undefined}
                        height={logoDimensions.height || undefined}
                        sizes="(min-width: 640px) 176px, 144px"
                      />
                    )}
                  </div>
                </a>
              ) : (
                <div class="card bg-base-100/80 h-full w-full">
                  <div class="card-body flex h-20 items-center justify-center p-4">
                    {logoUrl && (
                      <img
                        src={logoUrl}
                        srcset={logoSrcSet}
                        alt={logoLabel}
                        class={imageClass}
                        loading="lazy"
                        decoding="async"
                        width={logoDimensions.width || undefined}
                        height={logoDimensions.height || undefined}
                        sizes="(min-width: 640px) 176px, 144px"
                      />
                    )}
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    ) : (
      <ul class:list={['grid gap-3 sm:gap-4', gridClass]}>
        {logoItems.map((item: any, index: number) => {
          const logoUrl = getLogoUrl(item);
          const logoSrcSet = getLogoSrcSet(item);
          const logoDimensions = getLogoDimensions(item);
          const logoLabel = getLogoLabel(item, index);
          return (
            <li class="list-none">
              {item.url ? (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={logoLabel}
                  class="card bg-base-100/80 h-full transition hover:bg-base-100"
                >
                  <div class="card-body flex h-20 items-center justify-center p-4">
                    {logoUrl && (
                      <img
                        src={logoUrl}
                        srcset={logoSrcSet}
                        alt={logoLabel}
                        class={imageClass}
                        loading="lazy"
                        decoding="async"
                        width={logoDimensions.width || undefined}
                        height={logoDimensions.height || undefined}
                        sizes="(min-width: 1024px) 10vw, (min-width: 640px) 20vw, 40vw"
                      />
                    )}
                  </div>
                </a>
              ) : (
                <div class="card bg-base-100/80 h-full">
                  <div class="card-body flex h-20 items-center justify-center p-4">
                    {logoUrl && (
                      <img
                        src={logoUrl}
                        srcset={logoSrcSet}
                        alt={logoLabel}
                        class={imageClass}
                        loading="lazy"
                        decoding="async"
                        width={logoDimensions.width || undefined}
                        height={logoDimensions.height || undefined}
                        sizes="(min-width: 1024px) 10vw, (min-width: 640px) 20vw, 40vw"
                      />
                    )}
                  </div>
                </div>
              )}
            </li>
          );
        })}
      </ul>
    )}
  </div>
</section>
