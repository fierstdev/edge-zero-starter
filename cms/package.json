{
  "name": "@edge-zero/cms",
  "version": "1.0.0",
  "private": true,
  "description": "Starter CMS app for Edge Zero",
  "license": "Apache-2.0",
  "type": "module",
  "main": "src/payload.config.ts",
  "exports": {
    ".": "./src/payload.config.ts",
    "./payload-types": "./src/payload-types.ts",
    "./blocks": "./src/blocks/generated/index.ts",
    "./blocks/*": "./src/blocks/*",
    "./fields": "./src/public/fields.ts",
    "./fields/*": "./src/fields/*",
    "./fragments": "./src/public/fragments.ts",
    "./collections/*": "./src/collections/*",
    "./globals/*": "./src/globals/*",
    "./*": "./src/*"
  },
  "typesVersions": {
    "*": {
      "payload-types": ["src/payload-types.ts"],
      "blocks": ["src/blocks/generated/index.ts"],
      "blocks/*": ["src/blocks/*"],
      "fields": ["src/public/fields.ts"],
      "fields/*": ["src/fields/*"],
      "fragments": ["src/public/fragments.ts"],
      "collections/*": ["src/collections/*"],
      "globals/*": ["src/globals/*"],
      "*": ["src/*"]
    }
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "node --no-deprecation ./node_modules/next/dist/bin/next dev -p 3000",
    "dev:cf": "node --no-deprecation --import ./dev-vars.js ./node_modules/next/dist/bin/next dev -p 3000",
    "db:local": "wrangler d1 execute edge-zero-db --local --command='SELECT 1'",
    "db:repair:local": "node --import tsx ./scripts/repair-local-db.mts",
    "db:persist": "wrangler dev --port 3000 --local-persist ../../.wrangler-state",
    "devsafe": "rm -rf .next && node --no-deprecation ./node_modules/next/dist/bin/next dev -p 3000",
    "devsafe:cf": "rm -rf .next && node --no-deprecation --import ./dev-vars.js ./node_modules/next/dist/bin/next dev -p 3000",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/next": "3.78.0",
    "@payloadcms/storage-r2": "3.78.0",
    "@payloadcms/richtext-lexical": "3.78.0",
    "@payloadcms/ui": "3.78.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "15.5.14",
    "payload": "3.78.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "sharp": "0.34.2",
    "@payloadcms/db-d1-sqlite": "3.78.0",
    "@payloadcms/db-sqlite": "3.78.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.5.14",
    "jsdom": "28.0.0",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18",
    "wrangler": "^4.75.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  }
}
