---
// apps/frontend/src/pages/[...slug].astro
import Layout from '../layouts/Layout.astro';
import type { PageBlueprint, PageBlock } from '@edge-zero/types';

// 1. Import Block Components
import HeroBlock from '../components/blocks/core/HeroBlock.astro';
import FeatureGridBlock from '../components/blocks/core/FeatureGridBlock.astro';
import TestimonialBlock from '../components/blocks/trust/TestimonialBlock.astro';
import ServicesBlock from 'src/components/blocks/core/ServicesBlock.astro';
import ContactBlock from 'src/components/blocks/conversion/ContactBlock.astro';
import ValuePropositionBlock from 'src/components/blocks/core/ValuePropositionBlock.astro';
import AboutBlock from 'src/components/blocks/core/AboutBlock.astro';
// Core blocks finish here

// 2. The Component Registry
const ComponentRegistry: Record<string, any> = {
  HeroBlock: HeroBlock,
  FeatureGridBlock: FeatureGridBlock,
  TestimonialBlock: TestimonialBlock,
  ServicesBlock: ServicesBlock,
  ContactBlock: ContactBlock,
  ValuePropositionBlock: ValuePropositionBlock,
  AboutBlock: AboutBlock,
  // Antigravity will add new blocks here
};

// 3. Dynamic Routing Map
// If the user is at the root URL ("/"), slug is undefined. We map that to "home".
const { slug } = Astro.params;
const querySlug = slug || 'home'; 

// 4. The Data Pipeline (Fetch from Payload REST API)
// We use depth=2 to ensure nested relations (like Media assets) are fully populated
let pageData: PageBlueprint | null = null;

try {
  const response = await fetch(`http://localhost:3000/api/pages?where[slug][equals]=${querySlug}&depth=2`);
  
  if (!response.ok) {
    throw new Error(`Failed to fetch from Payload: ${response.statusText}`);
  }

  const data = await response.json();

  // If no page matches the slug, data.docs will be empty
  if (data.docs && data.docs.length > 0) {
    pageData = data.docs[0] as PageBlueprint;
  }
} catch (error) {
  console.error("Data Fetching Error:", error);
}

// 5. Handle 404s
if (!pageData) {
  return Astro.redirect('/404'); // You can create a 404.astro page later
}
---

<Layout seo={pageData.seo} themeOverride={pageData.themeOverride}>
  {pageData.blocks.map((block: PageBlock) => {
    // Look up the correct Astro component based on the Payload blockType
    const BlockComponent = ComponentRegistry[block.blockType];

    if (!BlockComponent) {
      // Graceful fallback for the factory floor
      console.warn(`[Edge Zero] Block type "${block.blockType}" is missing from the ComponentRegistry.`);
      return (
        <section class="py-12 text-center bg-error/10 text-error">
          <p class="font-mono text-sm">Missing Component: {block.blockType}</p>
        </section>
      );
    }

    // Render the exact component and pass the strictly typed data
    return <BlockComponent block={block} />;
  })}
</Layout>