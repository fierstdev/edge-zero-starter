---
import '../styles/global.css'; // Tailwind v4 + DaisyUI imports
import type { SEOData, GlobalTheme } from '@edge-zero/types';
import Footer from 'src/components/globals/Footer.astro';
import Header from 'src/components/globals/Header.astro';

interface Props {
  seo: SEOData;
  themeOverride?: string;
}

const { seo, themeOverride } = Astro.props;

let globalTheme: GlobalTheme | null = null;
try {
  const response = await fetch('http://localhost:3000/api/globals/theme?depth=1');
  if (response.ok) {
    globalTheme = await response.json();
  }
} catch (error) {
  console.error("Failed to fetch Theme global:", error);
}

// Fallbacks if CMS is unreachable
const currentTheme = themeOverride || globalTheme?.defaultTheme || 'light';
const sans = globalTheme?.fonts?.sans || 'Inter';
const heading = globalTheme?.fonts?.heading || 'Oswald';
const structure = globalTheme?.structure || {
  radiusBox: '1rem',
  radiusField: '0.25rem',
  radiusSelector: '1rem',
  borderSize: '1px',
  depth: '1',
  noise: '0'
};

const uniqueFonts = Array.from(new Set([sans, heading]));
const fontFamilies = uniqueFonts
  .map(font => `${font.replace(/\s+/g, '+')}:wght@400;500;600;700;800`)
  .join('&family=');

const googleFontsUrl = `https://fonts.googleapis.com/css2?family=${fontFamilies}&display=swap`;

const dynamicStyles = `
  --font-sans: "${sans}", sans-serif;
  --font-heading: "${heading}", sans-serif;
  --radius-box: ${structure.radiusBox};
  --radius-field: ${structure.radiusField};
  --radius-selector: ${structure.radiusSelector};
  --border: ${structure.borderSize};
  --depth: ${structure.depth};
  --noise: ${structure.noise};
`;
---

<!doctype html>
<html lang="en" data-theme={currentTheme} style={dynamicStyles}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href={googleFontsUrl} rel="stylesheet">

    {seo.noIndex && <meta name="robots" content="noindex, nofollow" />}
    {seo.canonicalUrl && <link rel="canonical" href={seo.canonicalUrl} />}
  </head>
  <body class="min-h-screen flex flex-col bg-base-100 text-base-content antialiased">
    
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />

    <script is:inline src="https://unpkg.com/lucide@latest"></script>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        if (window.lucide) {
          window.lucide.createIcons();
        }
      });
    </script>
  </body>
</html>