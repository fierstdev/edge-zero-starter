{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "astro",
    "types": ["astro/client"],
    "strictNullChecks": true,
    "allowJs": true,
    "noEmit": true,
    "paths": {
      "@edge-zero/cms-types": ["../types/src/index.ts"],
      "@edge-zero/cms/payload-types": ["../cms/src/payload-types.ts"]
    }
  },
  "include": [
    "src/**/*", 
    "astro.config.mjs"
  ],
  "exclude": [
    "dist", 
    "node_modules", 
    ".astro"
  ]
}
