{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "astro",
    "types": ["astro/client"],
    "strictNullChecks": true,
    "allowJs": true,
    "noEmit": true,
    "paths": {
      "@edge-zero/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": [
    "src/**/*", 
    "astro.config.mjs"
  ],
  "exclude": [
    "dist", 
    "node_modules", 
    ".astro"
  ]
}
