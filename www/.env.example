PUBLIC_CMS_URL=http://localhost:3000
PUBLIC_EDGEZERO_DASHBOARD_URL=http://localhost:3001
# 0 = always fetch fresh globals (recommended for local editing UX)
PUBLIC_CMS_GLOBAL_CACHE_TTL_MS=0

# Optional: contact form email notifications (Resend).
# If CONTACT_FORM_NOTIFY_TO is empty, submissions are stored in Payload only.
CONTACT_FORM_RESEND_API_KEY=
# Optional fallback key name also supported by the API route:
# RESEND_API_KEY=
CONTACT_FORM_NOTIFY_TO=
CONTACT_FORM_NOTIFY_FROM=onboarding@resend.dev
CONTACT_FORM_REPLY_TO_SUBMITTER=true
