import Layout from '../layouts/Layout.astro';
import BlockRenderer from '../components/BlockRenderer.astro';
import { fetchGlobalBundle, fetchPageBySlug } from '../lib/cms';
import { buildDefaultHomePage } from '../lib/default-home-page';

// 3. Dynamic Routing Map
// If the user is at the root URL ("/"), slug is undefined. Map that to "home".
const { slug } = Astro.params;
const querySlug = slug || 'home'; 
const dashboardUrl = import.meta.env.PUBLIC_EDGEZERO_DASHBOARD_URL || 'https://dashboard.edgezero.dev';

const assetLikePath = querySlug.split('/').pop() || '';
const isStaticAssetRequest = /\.[a-z0-9]+$/i.test(assetLikePath);

if (isStaticAssetRequest) {
  return new Response(null, { status: 404 });
}

if (!import.meta.env.DEV) {
  Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=60, stale-while-revalidate=300');
}

const [pageData, globalBundle] = await Promise.all([
  fetchPageBySlug(querySlug),
  fetchGlobalBundle(),
]);

const resolvedPageData = pageData || (querySlug === 'home' ? buildDefaultHomePage(dashboardUrl) : null);
const isNotFound = !resolvedPageData;

// 4. Handle 404s
if (isNotFound) {
  Astro.response.status = 404;
}

const fallbackNotFoundPage = {
  title: 'Page Not Found',
  seo: {
    title: 'Page Not Found | Edge Zero',
    description: 'The page you requested could not be found.',
    noIndex: true,
  },
  blocks: [],
  themeOverride: undefined,
};
const activePageData = resolvedPageData || fallbackNotFoundPage;
const { title, seo, blocks, themeOverride } = activePageData;
---

<Layout 
  seo={seo || { title }} 
  themeOverride={themeOverride}
  globals={globalBundle}
>
  <main>
    {isNotFound ? (
      <section class="mx-auto mt-16 max-w-3xl rounded-box border border-base-300 bg-base-100 p-8 text-center shadow-sm sm:mt-24 sm:p-12">
        <p class="badge badge-ghost">404</p>
        <h1 class="mt-4 text-4xl font-black tracking-tight sm:text-5xl">Page not found</h1>
        <p class="mt-4 text-base text-base-content/75 sm:text-lg">
          The link may be outdated, or the page may have been moved.
        </p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <a class="btn btn-primary" href="/">
            Back to Home
          </a>
          <a class="btn btn-outline" href={dashboardUrl.replace(/\/+$/, '')}>
            Open Dashboard
          </a>
        </div>
      </section>
    ) : (
      <>
        <h1 class="sr-only">{seo?.title || title}</h1>
        <BlockRenderer blocks={blocks} />
      </>
    )}
  </main>
</Layout>
