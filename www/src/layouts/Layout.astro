import '../styles/global.css';
import Header from '../components/globals/Header.astro';
import Footer from '../components/globals/Footer.astro';
import { fetchGlobal } from '../lib/cms';
import type {
  GlobalFooter,
  GlobalHeader,
  SiteIdentity,
} from '@edge-zero/cms-types';

interface Props {
  seo: {
    title: string;
    description?: string;
    noIndex?: boolean;
    canonicalUrl?: string;
  };
  title?: string;
  themeOverride?: string;
  globals?: {
    theme?: any | null;
    header?: GlobalHeader | null;
    identity?: SiteIdentity | null;
    footer?: GlobalFooter | null;
  };
}

const { seo, title, themeOverride, globals } = Astro.props;
const displayTitle = seo?.title || title || 'Edge Zero Starter';

const [globalTheme, globalHeader, globalIdentity, globalFooter] = globals
  ? [
      globals.theme ?? null,
      globals.header ?? null,
      globals.identity ?? null,
      globals.footer ?? null,
    ]
  : await Promise.all([
      fetchGlobal('theme'),
      fetchGlobal<GlobalHeader>('header'),
      fetchGlobal<SiteIdentity>('identity'),
      fetchGlobal<GlobalFooter>('footer'),
    ]);

// Fallbacks and Logic
const currentTheme = themeOverride || globalTheme?.defaultTheme || 'emerald';
const sans = globalTheme?.fonts?.sans || 'Inter';
const heading = globalTheme?.fonts?.heading || 'Oswald';
const logoFont = 'Bruno Ace';

const structure = globalTheme?.structure || {
  radiusBox: '1rem',
  radiusField: '0.25rem',
  radiusSelector: '1rem',
  borderSize: '1px',
  depth: '1',
  noise: '0'
};

// 4. Google Fonts Pipeline
const fontWeights = new Map<string, Set<string>>();
const addFontWeights = (font: string, weights: string[]) => {
  const existing = fontWeights.get(font) || new Set<string>();
  weights.forEach((weight) => existing.add(weight));
  fontWeights.set(font, existing);
};

addFontWeights(sans, ['400', '500', '600', '700']);
addFontWeights(heading, ['500', '600', '700', '800']);
addFontWeights(logoFont, ['400']);

const fontFamilies = Array.from(fontWeights.entries())
  .map(([font, weights]) => {
    const sortedWeights = Array.from(weights).sort((a, b) => Number(a) - Number(b));
    return `${font.replace(/\s+/g, '+')}:wght@${sortedWeights.join(';')}`;
  })
  .join('&family=');

const googleFontsUrl = `https://fonts.googleapis.com/css2?family=${fontFamilies}&display=swap`;

// 5. DaisyUI v5 & Tailwind v4 Dynamic Variables
const dynamicStyles = `
  --font-sans: "${sans}", sans-serif;
  --font-heading: "${heading}", sans-serif;
  --font-logo: "${logoFont}", sans-serif;
  --radius-box: ${structure.radiusBox};
  --radius-field: ${structure.radiusField};
  --radius-selector: ${structure.radiusSelector};
  --border: ${structure.borderSize};
  --depth: ${structure.depth};
  --noise: ${structure.noise};
`;
---

<!doctype html>
<html lang="en" data-theme={currentTheme} style={dynamicStyles}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{displayTitle}</title>
    {seo?.description && <meta name="description" content={seo.description} />}

    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={googleFontsUrl} />
    <link rel="stylesheet" href={googleFontsUrl} media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href={googleFontsUrl} />
    </noscript>

    {seo?.noIndex && <meta name="robots" content="noindex, nofollow" />}
    {seo?.canonicalUrl && <link rel="canonical" href={seo.canonicalUrl} />}
  </head>
  <body class="min-h-screen flex flex-col bg-base-100 text-base-content antialiased">
    
    <Header headerData={globalHeader} identityData={globalIdentity} />
    <main class="flex-grow relative overflow-hidden">
        <div class="fixed inset-0 pointer-events-none z-50 opacity-[var(--noise)] mix-blend-overlay bg-[radial-gradient(circle_at_1px_1px,color-mix(in_oklab,var(--color-base-content)_12%,transparent)_1px,transparent_0)] bg-[length:14px_14px]"></div>
        
        <slot />
    </main>
    <Footer footerData={globalFooter} />
  </body>
</html>
