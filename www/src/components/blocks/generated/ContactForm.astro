---
// AUTO-GENERATED BY EDGE ZERO COMPILER
// Tier: starter | Group: Foundation

export interface Props {
  block?: any;
  [key: string]: any; // Allows Payload system fields like id and blockType
}

const block = Astro.props.block ?? Astro.props;
const anchorId = block.anchorId;
const variant = block.variant || 'split';
const badge = block.badge;
const heading = block.heading;
const subheading = block.subheading;
const showContactDetails = block.showContactDetails !== false;
const detailsHeading = block.detailsHeading;
const emailLabel = block.emailLabel;
const email = block.email;
const phoneLabel = block.phoneLabel;
const phone = block.phone;
const addressLabel = block.addressLabel;
const address = block.address;
const formTitle = block.formTitle;
const nameLabel = block.nameLabel;
const emailFieldLabel = block.emailFieldLabel;
const messageLabel = block.messageLabel;
const includeCompanyField = Boolean(block.includeCompanyField);
const companyFieldLabel = block.companyFieldLabel;
const includePhoneField = Boolean(block.includePhoneField);
const phoneFieldLabel = block.phoneFieldLabel;
const includeSubjectField = Boolean(block.includeSubjectField);
const subjectFieldLabel = block.subjectFieldLabel;
const submitLabel = block.submitLabel;
const consentText = block.consentText;
const successMessage = block.successMessage;
const errorMessage = block.errorMessage;
const endpoint = block.endpoint || '/api/contact-form';

const badgeClass = badge?.color ? `badge-${badge.color}` : 'badge-primary';
const sectionId = anchorId || `${block?.id || 'contact'}-section`;
const headingId = `${sectionId}-heading`;
const requestStatus = Astro.url.searchParams.get('contactStatus');
const showSuccess = requestStatus === 'success';
const showError = requestStatus === 'error' || requestStatus === 'validation';
const returnPath = `${Astro.url.pathname}${anchorId ? `#${anchorId}` : ''}`;
const hasDetails = showContactDetails && variant !== 'minimal' && (email || phone || address);
const nameFieldId = `${sectionId}-name`;
const emailFieldId = `${sectionId}-email`;
const companyFieldId = `${sectionId}-company`;
const phoneFieldId = `${sectionId}-phone`;
const subjectFieldId = `${sectionId}-subject`;
const messageFieldId = `${sectionId}-message`;
const consentFieldId = `${sectionId}-consent`;
const honeypotFieldId = `${sectionId}-hp`;

---

<section id={anchorId || undefined} aria-labelledby={headingId} class="px-4 py-14 sm:py-18">
  <div class="mx-auto max-w-6xl space-y-8">
    <header class="max-w-3xl space-y-4">
      {badge?.label && (
        <span class={`badge ${badgeClass} ${badge?.size ? `badge-${badge.size}` : ''}`}>
          {badge.label}
        </span>
      )}
      <h2 id={headingId} class="text-3xl font-bold tracking-tight sm:text-4xl">{heading}</h2>
      {subheading && <p class="text-base text-base-content/80 sm:text-lg">{subheading}</p>}
    </header>

    {showSuccess && (
      <div class="alert alert-success" role="status" aria-live="polite">
        <span>{successMessage}</span>
      </div>
    )}

    {showError && (
      <div class="alert alert-error" role="alert">
        <span>{errorMessage}</span>
      </div>
    )}

    {variant === 'split' && (
      <div class="grid gap-5 lg:grid-cols-5">
        {hasDetails && (
          <aside class="card card-border bg-base-100 shadow-sm lg:col-span-2">
            <div class="card-body gap-5">
              <h3 class="card-title text-xl">{detailsHeading}</h3>
              <ul class="space-y-4 text-sm">
                {email && (
                  <li class="space-y-1">
                    <p class="font-semibold">{emailLabel}</p>
                    <a href={`mailto:${email}`} class="link link-hover break-all text-base-content/75">{email}</a>
                  </li>
                )}
                {phone && (
                  <li class="space-y-1">
                    <p class="font-semibold">{phoneLabel}</p>
                    <a href={`tel:${phone}`} class="link link-hover text-base-content/75">{phone}</a>
                  </li>
                )}
                {address && (
                  <li class="space-y-1">
                    <p class="font-semibold">{addressLabel}</p>
                    <p class="whitespace-pre-line text-base-content/75">{address}</p>
                  </li>
                )}
              </ul>
            </div>
          </aside>
        )}

        <div class:list={[
          'card card-border bg-base-100 shadow-sm',
          hasDetails ? 'lg:col-span-3' : 'lg:col-span-5',
        ]}>
          <div class="card-body">
            <h3 class="card-title text-xl">{formTitle}</h3>

            <form action={endpoint} method="post" class="space-y-4">
              <input type="hidden" name="redirectTo" value={returnPath} autocomplete="off" />
              <input type="hidden" name="pagePath" value={Astro.url.pathname} autocomplete="off" />
              <input type="hidden" name="pageUrl" value={Astro.url.href} autocomplete="off" />
              <input type="hidden" name="contactVariant" value={variant} autocomplete="off" />
              <input type="hidden" name="blockId" value={block?.id || ''} autocomplete="off" />
              <div class="hidden">
                <label for={honeypotFieldId}>Website</label>
                <input id={honeypotFieldId} type="text" name="company_website" autocomplete="off" />
              </div>

              <div class="space-y-2">
                <label class="label p-0" for={nameFieldId}>
                  <span class="label-text text-base-content/90">{nameLabel}</span>
                </label>
                <input id={nameFieldId} class="input w-full" type="text" name="name" autocomplete="name" required />
              </div>

              <div class="space-y-2">
                <label class="label p-0" for={emailFieldId}>
                  <span class="label-text text-base-content/90">{emailFieldLabel}</span>
                </label>
                <input id={emailFieldId} class="input w-full" type="email" name="email" autocomplete="email" required />
              </div>

              {includeCompanyField && (
                <div class="space-y-2">
                  <label class="label p-0" for={companyFieldId}>
                    <span class="label-text text-base-content/90">{companyFieldLabel}</span>
                  </label>
                  <input id={companyFieldId} class="input w-full" type="text" name="company" autocomplete="organization" />
                </div>
              )}

              {includePhoneField && (
                <div class="space-y-2">
                  <label class="label p-0" for={phoneFieldId}>
                    <span class="label-text text-base-content/90">{phoneFieldLabel}</span>
                  </label>
                  <input id={phoneFieldId} class="input w-full" type="tel" name="phone" autocomplete="tel" />
                </div>
              )}

              {includeSubjectField && (
                <div class="space-y-2">
                  <label class="label p-0" for={subjectFieldId}>
                    <span class="label-text text-base-content/90">{subjectFieldLabel}</span>
                  </label>
                  <input id={subjectFieldId} class="input w-full" type="text" name="subject" autocomplete="off" />
                </div>
              )}

              <div class="space-y-2">
                <label class="label p-0" for={messageFieldId}>
                  <span class="label-text text-base-content/90">{messageLabel}</span>
                </label>
                <textarea id={messageFieldId} class="textarea h-28 w-full" name="message" autocomplete="off" required />
              </div>

              {consentText && (
                <div class="space-y-2">
                  <label class="label cursor-pointer justify-start gap-2 p-0" for={consentFieldId}>
                    <input id={consentFieldId} class="checkbox checkbox-sm" type="checkbox" name="consent" autocomplete="off" required />
                    <span class="label-text text-base-content/90">{consentText}</span>
                  </label>
                </div>
              )}

              <button class="btn btn-primary btn-block sm:btn-wide sm:mx-auto" type="submit">{submitLabel}</button>
            </form>
          </div>
        </div>
      </div>
    )}

    {variant === 'card' && (
      <div class="grid place-items-center">
        <div class="card card-border bg-base-100 w-full max-w-3xl shadow-sm">
          <div class="card-body">
            <h3 class="card-title text-xl">{formTitle}</h3>
            <form action={endpoint} method="post" class="space-y-4">
              <input type="hidden" name="redirectTo" value={returnPath} autocomplete="off" />
              <input type="hidden" name="pagePath" value={Astro.url.pathname} autocomplete="off" />
              <input type="hidden" name="pageUrl" value={Astro.url.href} autocomplete="off" />
              <input type="hidden" name="contactVariant" value={variant} autocomplete="off" />
              <input type="hidden" name="blockId" value={block?.id || ''} autocomplete="off" />
              <input type="hidden" name="company_website" value="" autocomplete="off" />

              <div class="grid gap-4 sm:grid-cols-2">
                <div class="space-y-2">
                  <label class="label p-0" for={nameFieldId}>
                    <span class="label-text text-base-content/90">{nameLabel}</span>
                  </label>
                  <input id={nameFieldId} class="input w-full" type="text" name="name" autocomplete="name" required />
                </div>

                <div class="space-y-2">
                  <label class="label p-0" for={emailFieldId}>
                    <span class="label-text text-base-content/90">{emailFieldLabel}</span>
                  </label>
                  <input id={emailFieldId} class="input w-full" type="email" name="email" autocomplete="email" required />
                </div>
              </div>

              {includeSubjectField && (
                <div class="space-y-2">
                  <label class="label p-0" for={subjectFieldId}>
                    <span class="label-text text-base-content/90">{subjectFieldLabel}</span>
                  </label>
                  <input id={subjectFieldId} class="input w-full" type="text" name="subject" autocomplete="off" />
                </div>
              )}

              <div class="space-y-2">
                <label class="label p-0" for={messageFieldId}>
                  <span class="label-text text-base-content/90">{messageLabel}</span>
                </label>
                <textarea id={messageFieldId} class="textarea h-28 w-full" name="message" autocomplete="off" required />
              </div>

              <button class="btn btn-primary btn-block sm:btn-wide sm:mx-auto" type="submit">{submitLabel}</button>
            </form>
          </div>
        </div>
      </div>
    )}

    {variant === 'minimal' && (
      <div class="card card-border bg-base-100 shadow-sm">
        <div class="card-body">
          <form action={endpoint} method="post" class="space-y-4">
            <input type="hidden" name="redirectTo" value={returnPath} autocomplete="off" />
            <input type="hidden" name="pagePath" value={Astro.url.pathname} autocomplete="off" />
            <input type="hidden" name="pageUrl" value={Astro.url.href} autocomplete="off" />
            <input type="hidden" name="contactVariant" value={variant} autocomplete="off" />
            <input type="hidden" name="blockId" value={block?.id || ''} autocomplete="off" />
            <input type="hidden" name="company_website" value="" autocomplete="off" />

            <div class="grid gap-4 md:grid-cols-3">
              <div class="space-y-2 md:col-span-1">
                <label class="sr-only" for={nameFieldId}>{nameLabel}</label>
                <input id={nameFieldId} class="input w-full" type="text" name="name" autocomplete="name" required />
              </div>
              <div class="space-y-2 md:col-span-1">
                <label class="sr-only" for={emailFieldId}>{emailFieldLabel}</label>
                <input id={emailFieldId} class="input w-full" type="email" name="email" autocomplete="email" required />
              </div>
              <button class="btn btn-primary md:col-span-1" type="submit">{submitLabel}</button>
            </div>
            <div class="space-y-2">
              <label class="sr-only" for={messageFieldId}>{messageLabel}</label>
              <textarea id={messageFieldId} class="textarea h-28 w-full" name="message" autocomplete="off" required />
            </div>
          </form>
        </div>
      </div>
    )}
  </div>
</section>
