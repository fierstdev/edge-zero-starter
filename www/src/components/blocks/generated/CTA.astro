---
// AUTO-GENERATED BY EDGE ZERO COMPILER
// Tier: starter | Group: Foundation

import { resolveMediaUrl, resolveMediaSrcSet, resolveMediaDimensions } from '../../../lib/media';

export interface Props {
  block?: any;
  [key: string]: any; // Allows Payload system fields like id and blockType
}

const block = Astro.props.block ?? Astro.props;
const anchorId = block.anchorId;
const variant = block.variant || 'banner';
const badge = block.badge;
const heading = block.heading;
const subheading = block.subheading;
const primaryAction = block.primaryAction;
const secondaryAction = block.secondaryAction;
const finePrint = block.finePrint;
const backgroundImage = block.backgroundImage;
const panelTitle = block.panelTitle;
const panelItems = Array.isArray(block.panelItems) ? block.panelItems : [];
const blockIndex = Number(block.blockIndex || 0);

const badgeClass = badge?.color ? `badge-${badge.color}` : 'badge-primary';
const sectionId = anchorId || `${block?.id || 'cta'}-section`;
const headingId = `${sectionId}-heading`;
const backgroundImageUrl = resolveMediaUrl(backgroundImage, ['feature', 'card', 'thumbnail', 'hero']);
const backgroundImageSrcSet = resolveMediaSrcSet(backgroundImage, ['thumbnail', 'card', 'feature', 'hero']);
const backgroundImageDimensions = resolveMediaDimensions(backgroundImage, ['feature', 'hero']);
const isPriorityMedia = blockIndex === 0;
const bannerSizes = '(min-width: 1200px) 1152px, 100vw';

const toButtonClass = (action?: any, isPrimary?: boolean) => {
  const defaultStyle = isPrimary ? 'btn-primary' : 'btn-outline';
  const styleClass = action?.style ? `btn-${action.style}` : defaultStyle;
  const sizeClass = action?.size ? `btn-${action.size}` : 'btn-md';
  return `btn ${styleClass} ${sizeClass} w-full sm:w-auto`;
};

---

<section id={anchorId || undefined} aria-labelledby={headingId} class="px-4 py-14 sm:py-18 lg:py-22">
  <div class="mx-auto max-w-6xl">
    {variant === 'banner' && (
      <div class="hero relative overflow-hidden bg-base-200/25 min-h-[22rem]">
        {backgroundImageUrl && (
          <>
            <img
              src={backgroundImageUrl}
              srcset={backgroundImageSrcSet}
              alt={backgroundImage?.altText || ''}
              class="absolute inset-0 h-full w-full object-cover"
              loading={isPriorityMedia ? 'eager' : 'lazy'}
              fetchpriority={isPriorityMedia ? 'high' : 'auto'}
              decoding="async"
              width={backgroundImageDimensions.width || undefined}
              height={backgroundImageDimensions.height || undefined}
              sizes={bannerSizes}
            />
            <div class="hero-overlay bg-base-100/75"></div>
          </>
        )}

        <div class="hero-content relative text-center py-10 sm:py-12">
          <div class="max-w-3xl space-y-5">
            {badge?.label && (
              <span class={`badge ${badgeClass} ${badge?.size ? `badge-${badge.size}` : ''}`}>
                {badge.label}
              </span>
            )}
            <h2 id={headingId} class="text-3xl font-black tracking-tight sm:text-5xl">
              {heading}
            </h2>
            {subheading && <p class="text-base text-base-content/80 sm:text-lg">{subheading}</p>}

            <div class="flex flex-col justify-center gap-3 pt-2 sm:flex-row sm:flex-wrap">
              {primaryAction?.url && primaryAction?.label && (
                <a
                  href={primaryAction.url}
                  target={primaryAction.target === '_blank' ? '_blank' : undefined}
                  rel={primaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                  class={toButtonClass(primaryAction, true)}
                >
                  {primaryAction.label}
                </a>
              )}
              {secondaryAction?.url && secondaryAction?.label && (
                <a
                  href={secondaryAction.url}
                  target={secondaryAction.target === '_blank' ? '_blank' : undefined}
                  rel={secondaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                  class={toButtonClass(secondaryAction, false)}
                >
                  {secondaryAction.label}
                </a>
              )}
            </div>

            {finePrint && <p class="text-sm text-base-content/80">{finePrint}</p>}
          </div>
        </div>
      </div>
    )}

    {variant === 'card' && (
      <div class="grid place-items-center">
        <article class="card card-border bg-base-100 w-full max-w-3xl shadow-sm">
          <div class="card-body items-center text-center gap-5 p-7 sm:p-10">
            {badge?.label && (
              <span class={`badge ${badgeClass} ${badge?.size ? `badge-${badge.size}` : ''}`}>
                {badge.label}
              </span>
            )}
            <h2 id={headingId} class="text-3xl font-black tracking-tight sm:text-4xl">{heading}</h2>
            {subheading && <p class="max-w-2xl text-base text-base-content/80 sm:text-lg">{subheading}</p>}

            <div class="card-actions w-full justify-center">
              <div class="flex w-full flex-col gap-3 sm:w-auto sm:flex-row">
                {primaryAction?.url && primaryAction?.label && (
                  <a
                    href={primaryAction.url}
                    target={primaryAction.target === '_blank' ? '_blank' : undefined}
                    rel={primaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                    class={toButtonClass(primaryAction, true)}
                  >
                    {primaryAction.label}
                  </a>
                )}
                {secondaryAction?.url && secondaryAction?.label && (
                  <a
                    href={secondaryAction.url}
                    target={secondaryAction.target === '_blank' ? '_blank' : undefined}
                    rel={secondaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                    class={toButtonClass(secondaryAction, false)}
                  >
                    {secondaryAction.label}
                  </a>
                )}
              </div>
            </div>

            {finePrint && <p class="text-sm text-base-content/80">{finePrint}</p>}
          </div>
        </article>
      </div>
    )}

    {variant === 'split-panel' && (
      <div class="grid gap-6 bg-base-200/30 p-6 sm:p-8 lg:grid-cols-12 lg:p-12">
        <div class="space-y-5 lg:col-span-7">
          {badge?.label && (
            <span class={`badge ${badgeClass} ${badge?.size ? `badge-${badge.size}` : ''}`}>
              {badge.label}
            </span>
          )}

          <h2 id={headingId} class="text-3xl font-black tracking-tight sm:text-5xl">{heading}</h2>
          {subheading && <p class="max-w-2xl text-base text-base-content/75 sm:text-lg">{subheading}</p>}

          <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            {primaryAction?.url && primaryAction?.label && (
              <a
                href={primaryAction.url}
                target={primaryAction.target === '_blank' ? '_blank' : undefined}
                rel={primaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                class={toButtonClass(primaryAction, true)}
              >
                {primaryAction.label}
              </a>
            )}
            {secondaryAction?.url && secondaryAction?.label && (
              <a
                href={secondaryAction.url}
                target={secondaryAction.target === '_blank' ? '_blank' : undefined}
                rel={secondaryAction.target === '_blank' ? 'noreferrer noopener' : undefined}
                class={toButtonClass(secondaryAction, false)}
              >
                {secondaryAction.label}
              </a>
            )}
          </div>
        </div>

        <aside class="card card-border bg-base-100 lg:col-span-5">
          <div class="card-body gap-4">
            {panelTitle && <h3 class="card-title text-xl">{panelTitle}</h3>}
            <ul class="space-y-2 text-sm text-base-content/75">
              {panelItems.map((entry: any) => (
                <li class="flex items-start gap-2 border-b border-base-300 pb-2 last:border-b-0 last:pb-0">
                  <span class="mt-0.5 text-success" aria-hidden="true">●</span>
                  <span>{entry.item}</span>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    )}
  </div>
</section>
