---
// AUTO-GENERATED BY EDGE ZERO COMPILER
// Tier: starter | Group: Foundation

import Icon from '../../../components/ui/Icon.astro';
import { resolveMediaUrl, resolveMediaSrcSet, resolveMediaDimensions } from '../../../lib/media';

export interface Props {
  block?: any;
  [key: string]: any; // Allows Payload system fields like id and blockType
}

const block = Astro.props.block ?? Astro.props;
const anchorId = block.anchorId;
const variant = block.variant || 'grid';
const badge = block.badge;
const heading = block.heading;
const subheading = block.subheading;
const columns = block.columns;
const spotlightMedia = block.spotlightMedia;
const spotlightMediaPosition = block.spotlightMediaPosition;
const features = block.features;

const badgeClass = badge?.color ? `badge-${badge.color}` : 'badge-primary';
const sectionId = anchorId || `${block?.id || 'features'}-section`;
const headingId = `${sectionId}-heading`;
const featureItems = Array.isArray(features) ? features : [];
const spotlightMediaUrl = resolveMediaUrl(spotlightMedia, ['feature', 'card', 'thumbnail', 'hero']);
const spotlightMediaSrcSet = resolveMediaSrcSet(spotlightMedia, ['thumbnail', 'card', 'feature', 'hero']);
const spotlightMediaDimensions = resolveMediaDimensions(spotlightMedia, ['card', 'feature', 'hero']);
const useLeftMedia = spotlightMediaPosition === 'left';
const [spotlightPrimary, ...spotlightSecondary] = featureItems;

const gridClass =
  columns === '2'
    ? 'md:grid-cols-2'
    : columns === '4'
      ? 'md:grid-cols-2 xl:grid-cols-4'
      : 'md:grid-cols-2 lg:grid-cols-3';

const toButtonClass = (action?: any) => {
  const styleClass = action?.style ? `btn-${action.style}` : 'btn-outline';
  const sizeClass = action?.size ? `btn-${action.size}` : 'btn-sm';
  return `btn ${styleClass} ${sizeClass}`;
};

---

<section id={anchorId || undefined} aria-labelledby={headingId} class="px-4 py-14 sm:py-18">
  <div class="mx-auto max-w-6xl space-y-8">
    <header class="max-w-3xl space-y-4">
      {badge?.label && (
        <span class={`badge ${badgeClass} ${badge?.size ? `badge-${badge.size}` : ''}`}>
          {badge.label}
        </span>
      )}
      <h2 id={headingId} class="text-3xl font-bold tracking-tight sm:text-4xl">{heading}</h2>
      {subheading && <p class="text-base text-base-content/80 sm:text-lg">{subheading}</p>}
    </header>

    {variant === 'grid' && (
      <div class:list={['grid gap-5 sm:gap-6', gridClass]}>
        {featureItems.map((feature: any, index: number) => (
          <article class="card card-border bg-base-100 h-full shadow-sm">
            <div class="card-body gap-4">
              <div class="inline-flex size-11 items-center justify-center rounded-box bg-primary/10 text-primary">
                {feature.icon ? (
                  <Icon icon={feature.icon} class="size-5" />
                ) : (
                  <span class="text-sm font-semibold">{index + 1}</span>
                )}
              </div>
              <h3 class="card-title text-xl">{feature.title}</h3>
              <p class="text-sm leading-relaxed text-base-content/80">{feature.description}</p>
              {feature.action?.url && feature.action?.label && (
                <div class="card-actions mt-2">
                  <a
                    href={feature.action.url}
                    target={feature.action.target === '_blank' ? '_blank' : undefined}
                    rel={feature.action.target === '_blank' ? 'noreferrer noopener' : undefined}
                    class={toButtonClass(feature.action)}
                  >
                    {feature.action.label}
                  </a>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    )}

    {variant === 'list' && (
      <ul class="list bg-base-200/20">
        {featureItems.map((feature: any, index: number) => (
          <li class="list-row items-start gap-4 p-5 sm:p-6">
            <div class="inline-flex size-10 shrink-0 items-center justify-center rounded-box bg-primary/10 text-primary">
              {feature.icon ? (
                <Icon icon={feature.icon} class="size-5" />
              ) : (
                <span class="text-sm font-semibold">{index + 1}</span>
              )}
            </div>
            <div class="list-col-grow space-y-1">
              <h3 class="font-semibold">{feature.title}</h3>
              <p class="text-sm text-base-content/80">{feature.description}</p>
            </div>
            {feature.action?.url && feature.action?.label && (
              <a
                href={feature.action.url}
                target={feature.action.target === '_blank' ? '_blank' : undefined}
                rel={feature.action.target === '_blank' ? 'noreferrer noopener' : undefined}
                class={toButtonClass(feature.action)}
              >
                {feature.action.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    )}

    {variant === 'spotlight' && (
      <div class:list={[
        'grid items-start gap-6 bg-base-200/25 p-6 sm:p-8 lg:grid-cols-12 lg:p-10',
        useLeftMedia ? 'lg:[&>*:first-child]:order-2 lg:[&>*:last-child]:order-1' : '',
      ]}>
        <div class="space-y-4 lg:col-span-6">
          {spotlightPrimary && (
            <article class="card card-border bg-base-100 shadow-sm">
              <div class="card-body gap-4">
                <div class="inline-flex size-11 items-center justify-center rounded-box bg-primary/10 text-primary">
                  {spotlightPrimary.icon ? <Icon icon={spotlightPrimary.icon} class="size-5" /> : <span class="text-sm font-semibold">1</span>}
                </div>
                <h3 class="card-title text-2xl">{spotlightPrimary.title}</h3>
                <p class="text-sm leading-relaxed text-base-content/80 sm:text-base">{spotlightPrimary.description}</p>
                {spotlightPrimary.action?.url && spotlightPrimary.action?.label && (
                  <div class="card-actions mt-1">
                    <a
                      href={spotlightPrimary.action.url}
                      target={spotlightPrimary.action.target === '_blank' ? '_blank' : undefined}
                      rel={spotlightPrimary.action.target === '_blank' ? 'noreferrer noopener' : undefined}
                      class={toButtonClass(spotlightPrimary.action)}
                    >
                      {spotlightPrimary.action.label}
                    </a>
                  </div>
                )}
              </div>
            </article>
          )}

          {spotlightSecondary.length > 0 && (
            <div class="space-y-3">
              {spotlightSecondary.map((feature: any, index: number) => (
                <article class="card card-border bg-base-100 shadow-sm">
                  <div class="card-body gap-2 py-4 sm:py-5">
                    <div class="flex items-start gap-3">
                      <div class="inline-flex size-10 shrink-0 items-center justify-center rounded-box bg-primary/10 text-primary">
                        {feature.icon ? (
                          <Icon icon={feature.icon} class="size-5" />
                        ) : (
                          <span class="text-sm font-semibold">{index + 2}</span>
                        )}
                      </div>
                      <h4 class="pt-1 font-semibold">{feature.title}</h4>
                    </div>
                    <p class="text-sm text-base-content/80">{feature.description}</p>
                    {feature.action?.url && feature.action?.label && (
                      <div class="card-actions mt-1">
                        <a
                          href={feature.action.url}
                          target={feature.action.target === '_blank' ? '_blank' : undefined}
                          rel={feature.action.target === '_blank' ? 'noreferrer noopener' : undefined}
                          class={toButtonClass(feature.action)}
                        >
                          {feature.action.label}
                        </a>
                      </div>
                    )}
                  </div>
                </article>
              ))}
            </div>
          )}
        </div>

        {spotlightMediaUrl && (
          <figure class="overflow-hidden rounded-box lg:col-span-6">
            <img
              src={spotlightMediaUrl}
              srcset={spotlightMediaSrcSet}
              alt={spotlightMedia?.altText || ''}
              class="h-full w-full object-cover"
              loading="lazy"
              decoding="async"
              width={spotlightMediaDimensions.width || undefined}
              height={spotlightMediaDimensions.height || undefined}
              sizes="(min-width: 1200px) 576px, (min-width: 1024px) 50vw, 100vw"
            />
          </figure>
        )}
      </div>
    )}
  </div>
</section>
