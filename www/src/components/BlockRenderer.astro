import { BlockMap as StarterBlockMap } from './blocks/generated/index.js';

interface Props {
  blocks: any[];
}

const { blocks = [] } = Astro.props;
const enableProBlocks = import.meta.env.PUBLIC_EDGE_ZERO_ENABLE_PRO === 'true';
const proBlockMapImportPath = import.meta.env.PUBLIC_EDGE_ZERO_PRO_BLOCKMAP_IMPORT;

let proBlockMap: Record<string, any> = {};

if (enableProBlocks && proBlockMapImportPath) {
  try {
    ({ BlockMap: proBlockMap } = await import(/* @vite-ignore */ proBlockMapImportPath));
  } catch (error) {
    console.warn('Edge Zero starter/www could not load Pro blocks for development.', error);
  }
} else if (enableProBlocks) {
  console.warn('Edge Zero starter/www: PUBLIC_EDGE_ZERO_PRO_BLOCKMAP_IMPORT is not set; skipping Pro block map.');
}

const BlockMap = {
  ...StarterBlockMap,
  ...proBlockMap,
};
---

{blocks.map((block, blockIndex) => {
  const BlockComponent = BlockMap[block.blockType];

  if (!BlockComponent) {
    return (
      <section class="py-12 text-center bg-error/10 text-error">
        <p class="font-mono text-sm">Missing Component: {block.blockType}</p>
      </section>
    );
  }

  return <BlockComponent {...block} blockIndex={blockIndex} />;
})}
