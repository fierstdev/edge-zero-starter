---
import type { ContactBlock as ContactPayload } from '@edge-zero/types';

interface Props {
  block: ContactPayload;
}

const { block } = Astro.props;

const paddingClass = block.paddingTop === 'xl' ? 'pt-32 pb-32' : 'py-16';
---

<section 
  id={block.anchorId || block.id} 
  data-theme={block.themeOverride} 
  class={`w-full bg-base-100 ${paddingClass}`}
>
  <div class="container mx-auto px-4">
    <div class="flex flex-col lg:flex-row gap-12 max-w-6xl mx-auto">
      
      {/* Contact Info Side */}
      <div class="flex-1 space-y-6">
        <h2 class="text-4xl md:text-5xl font-bold text-base-content">{block.heading}</h2>
        {block.subheading && (
          <p class="text-xl text-base-content/80">
            {block.subheading}
          </p>
        )}
        
        <div class="space-y-4 mt-8">
          {block.email && (
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold">Email</h3>
                <a href={`mailto:${block.email}`} class="text-base-content/70 hover:text-primary transition-colors">{block.email}</a>
              </div>
            </div>
          )}
          
          {block.phone && (
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold">Phone</h3>
                <a href={`tel:${block.phone}`} class="text-base-content/70 hover:text-primary transition-colors">{block.phone}</a>
              </div>
            </div>
          )}
          
          {block.address && (
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold">Address</h3>
                <span class="text-base-content/70 block whitespace-pre-wrap">{block.address}</span>
              </div>
            </div>
          )}
        </div>
      </div>
      
      {/* Contact Form Side */}
      {block.showForm !== false && (
        <div class="flex-1">
          <div class="card bg-base-200 shadow-xl">
            <div class="card-body">
              <form class="space-y-4" onsubmit="event.preventDefault(); alert('Form submitted! This is a mock interaction.');">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <fieldset class="fieldset w-full">
                    <legend class="fieldset-legend">First Name<span class="text-error">*</span></legend>
                    <input type="text" class="input w-full" placeholder="John" required />
                  </fieldset>

                  <fieldset class="fieldset w-full">
                    <legend class="fieldset-legend">Last Name<span class="text-error">*</span></legend>
                    <input type="text" class="input w-full" placeholder="Doe" required />
                  </fieldset>
                </div>

                <fieldset class="fieldset w-full">
                  <legend class="fieldset-legend">Email Address<span class="text-error">*</span></legend>
                  <input type="email" class="input w-full" placeholder="john@example.com" required />
                </fieldset>

                <fieldset class="fieldset w-full">
                  <legend class="fieldset-legend">Message<span class="text-error">*</span></legend>
                  <textarea class="textarea w-full h-32" placeholder="How can we help you?" required></textarea>
                </fieldset>

                <div class="card-actions justify-end pt-4">
                  <button type="submit" class="btn btn-primary w-full md:w-auto">Send Message</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      )}
      
    </div>
  </div>
</section>
