---
import type { TestimonialBlock as TestimonialPayload } from '@edge-zero/types';
import { resolveMediaUrl } from 'src/lib/media';

interface Props {
  block: TestimonialPayload;
}

const { block } = Astro.props;

const paddingClass = block.paddingTop === 'xl' ? 'pt-32 pb-32' : 'py-16';

// Determine the grid/flex classes based on layout
let gridClass = 'grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3';
if (block.layout === 'slider') {
  gridClass = 'flex gap-6 overflow-x-auto snap-x pb-4';
} else if (block.layout === 'featured') {
  gridClass = 'grid gap-8 grid-cols-1 max-w-4xl mx-auto';
}
---

<section 
  id={block.anchorId || block.id} 
  data-theme={block.themeOverride} 
  class={`w-full bg-base-200 ${paddingClass}`}
>
  <div class="container mx-auto px-4">
    {block.heading && (
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-base-content">{block.heading}</h2>
      </div>
    )}

    <div class={gridClass}>
      {block.testimonials.map((testimonial) => (
        <div class={`card bg-base-100 shadow-sm ${block.layout === 'slider' ? 'min-w-[300px] snap-center' : ''}`}>
          <div class="card-body gap-6">
            {testimonial.rating && (
              <div class="rating rating-sm">
                {[1, 2, 3, 4, 5].map((star) => (
                  <div
                    class={`mask mask-star ${star <= testimonial.rating! ? 'bg-warning' : 'bg-base-300'}`}
                    aria-label={`${star} star`}
                    {...(star === testimonial.rating! ? { 'aria-current': 'true' } : {})}
                  ></div>
                ))}
              </div>
            )}
            
            <p class={`text-base-content/80 italic ${block.layout === 'featured' ? 'text-2xl' : 'text-lg'}`}>
              "{testimonial.quote}"
            </p>
            
            <div class="flex items-center gap-4 mt-auto pt-4">
              <div class="avatar">
                <div class="w-12 h-12 rounded-full bg-neutral text-neutral-content flex items-center justify-center overflow-hidden">
                  {testimonial.authorImage ? (
                    <img src={resolveMediaUrl(testimonial.authorImage.url)} alt={`Photo of ${testimonial.authorName}`} class="w-full h-full object-cover" />
                  ) : (
                    <span class="text-xl font-bold">{testimonial.authorName.charAt(0)}</span>
                  )}
                </div>
              </div>
              <div class="flex flex-col">
                <span class="font-bold text-base-content">{testimonial.authorName}</span>
                {(testimonial.authorRole || testimonial.authorCompany) && (
                  <span class="text-sm text-base-content/60">
                    {testimonial.authorRole}{testimonial.authorRole && testimonial.authorCompany ? ', ' : ''}{testimonial.authorCompany}
                  </span>
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
