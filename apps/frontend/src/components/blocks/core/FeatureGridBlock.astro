---
import type { FeatureGridBlock as FeatureGridPayload } from '@edge-zero/types';
import { resolveMediaUrl } from 'src/lib/media';

interface Props {
  block: FeatureGridPayload;
}

const { block } = Astro.props;

// Tailwind v4 responsive grid columns mapping
const gridCols = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4',
}[block.columns] || 'grid-cols-1 md:grid-cols-3';
---

<section id={block.anchorId || block.id} class="w-full bg-base-200 py-24">
  <div class="container mx-auto px-4 max-w-7xl">
    
    {block.heading && (
      <div class={`mb-12 flex flex-col gap-4 ${block.alignment === 'center' ? 'text-center items-center' : 'text-left items-start'}`}>
        <h2 class="text-4xl md:text-5xl font-bold text-base-content tracking-tight">
          {block.heading}
        </h2>
        {block.subheading && (
          <p class="text-lg text-base-content/70 max-w-2xl">
            {block.subheading}
          </p>
        )}
      </div>
    )}

    <div class={`grid gap-6 md:gap-8 ${gridCols}`}>
      {block.features?.map((feature) => (
        <div class="card bg-base-100 shadow-sm border border-base-content/10">
          <div class="card-body">
            {feature.icon && (
              <div class="mb-4">
                {feature.icon.type === 'image' ? (
                  <img src={resolveMediaUrl(feature.icon.value)} alt="" class="w-12 h-12 object-contain" />
                ) : (
                  <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                    {feature.icon.type === 'lucide' ? (
                      <i data-lucide={feature.icon.value} class="w-6 h-6"></i>
                    ) : (
                      <div set:html={feature.icon.value} class="w-6 h-6 [&>svg]:w-full [&>svg]:h-full" />
                    )}
                  </div>
                )}
              </div>
            )}
            <h3 class="card-title text-xl text-base-content">{feature.title}</h3>
            <p class="text-base-content/80 mt-2">{feature.description}</p>
            
            {feature.link && (
              <div class="card-actions justify-start mt-4">
                <a 
                  href={feature.link.url} 
                  target={feature.link.target === '_blank' ? '_blank' : undefined}
                  rel={feature.link.target === '_blank' ? 'noopener noreferrer' : undefined}
                  class={`btn btn-sm btn-${feature.link.style || 'primary'} ${feature.link.style === 'link' || feature.link.style === 'outline' ? '' : 'shadow-sm'}`}
                >
                  {feature.link.label}
                </a>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
    
  </div>
</section>