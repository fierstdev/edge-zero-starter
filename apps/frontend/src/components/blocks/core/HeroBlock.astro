---
import type { HeroBlock as HeroPayload } from '@edge-zero/types';
import { resolveMediaUrl } from 'src/lib/media';

interface Props {
  block: HeroPayload;
}

const { block } = Astro.props;

const paddingClass = block.paddingTop === 'xl' ? 'pt-32 pb-32' : 'py-16 mt-8';

// Variant mappings
const isCinematic = block.variant === 'cinematic';
const isSplit = block.variant === 'split';

const hasPopulatedMedia = !!block.media && typeof block.media === 'object';

// Split handling
const isMediaLeft = isSplit && block.mediaPosition === 'left';
const flexLayoutClass = isMediaLeft ? 'lg:flex-row-reverse' : 'lg:flex-row';

// Text Alignment Mapping
const alignClass = isSplit ? 'text-left items-start' : 'text-center items-center';

const bgStyle = isCinematic && hasPopulatedMedia && typeof block.media === 'object' 
    ? { backgroundImage: `url('${resolveMediaUrl(block.media?.url)}')` } 
    : undefined;
---

<section 
  id={block.anchorId || block.id} 
  data-theme={block.themeOverride} 
  class={`w-full ${isCinematic ? 'hero min-h-[85vh] bg-cover bg-center bg-no-repeat relative' : `bg-base-100 ${paddingClass}`}`}
  style={bgStyle}
>
  {isCinematic && <div class="hero-overlay bg-neutral/60 absolute inset-0 z-0"></div>}

  <div class={`container mx-auto px-4 ${isCinematic ? 'hero-content text-neutral-content z-10 relative mt-16' : ''}`}>
    <div class={`flex flex-col ${isSplit ? `${flexLayoutClass} items-center gap-12 lg:gap-20` : 'gap-6'}`}>
      
      {/* Text Content */}
      <div class={`flex flex-col gap-6 w-full ${isSplit ? 'lg:w-1/2' : 'max-w-4xl mx-auto'} ${alignClass}`}>
        
        {block.badge?.label && (
          <span class={`badge ${block.badge.color ? `badge-${block.badge.color}` : 'badge-primary'} ${block.badge.size ? `badge-${block.badge.size}` : ''} ${block.badge.isOutline ? 'badge-outline' : ''} font-semibold shadow-sm w-fit`}>
            {block.badge.label}
          </span>
        )}
        
        <h1 class={`text-5xl font-extrabold md:text-7xl text-balance tracking-tight ${isCinematic ? 'text-white drop-shadow-lg' : 'text-base-content'}`}>
          {block.heading}
        </h1>
        
        {block.subheading && (
          <p class={`text-xl max-w-2xl text-pretty font-medium opacity-90 ${isCinematic ? 'text-white drop-shadow-md' : 'text-base-content/80'}`}>
            {block.subheading}
          </p>
        )}
        
        {block.actions && block.actions.length > 0 && (
          <div class={`flex flex-wrap gap-4 mt-6 ${isSplit ? 'justify-start' : 'justify-center'}`}>
            {block.actions.map((actionItem: any) => {
              const link = actionItem.link; 
              if (!link || !link.label || !link.url) return null;
              
              let styleClass = `btn-${link.style || 'primary'}`;
              
              if (link.style === 'outline') {
                styleClass = 'btn-outline';
              } else if (link.style === 'link') {
                styleClass = 'btn-link';
              }
              
              const btnClass = `btn ${styleClass} ${link.size ? `btn-${link.size}` : ''} shadow-md hover:shadow-lg transition-all hover:-translate-y-0.5`;
              
              return (
                <a 
                  href={link.url} 
                  target={link.target === '_blank' ? '_blank' : undefined}
                  rel={link.target === '_blank' ? 'noopener noreferrer' : undefined}
                  class={btnClass}
                >
                  {link.label}
                </a>
              );
            })}
          </div>
        )}
      </div>

      {/* Media Figure (Split variant only) */}
      {isSplit && hasPopulatedMedia && typeof block.media === 'object' && block.media && (
        <div class="w-full lg:w-1/2">
           <figure class="w-full aspect-square md:aspect-[4/3] rounded-[2rem] overflow-hidden shadow-2xl relative group">
              <div class="absolute inset-0 bg-primary/10 group-hover:bg-primary/5 transition-colors duration-500 z-10 pointer-events-none mix-blend-overlay"></div>
              <img 
                src={resolveMediaUrl(block.media.url)} 
                alt={block.media.altText || ''} 
                class="w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-105"
              />
           </figure>
        </div>
      )}

    </div>
  </div>
</section>